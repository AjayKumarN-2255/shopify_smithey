                        </g>
                        <path d="M5.58814 6.10059V2.27294C5.58814 2.20152 5.57161 2.14068 5.53672 2.09042C5.49999 2.04016 5.45775 2.01636 5.40817 2.01636C5.36043 2.01636 5.31819 2.04016 5.28146 2.09042C5.24657 2.14068 5.23004 2.20152 5.23004 2.27294V6.2064C5.23004 6.27782 5.24657 6.33866 5.28146 6.39157L6.83322 8.62414C6.86811 8.6744 6.91035 8.70085 6.95993 8.70085C7.00951 8.70085 7.05175 8.6744 7.08664 8.62414C7.12153 8.57388 7.1399 8.51304 7.1399 8.44162C7.1399 8.3702 7.12153 8.30936 7.08664 8.2591L5.58814 6.10059Z" fill="white"></path>
                      </svg>
                      {{ article.metafields.custom.cook_time }}
                    </span>

                    <span class="recipe-card__product"> {{ article.metafields.custom.related_products.value.title  }} </span>
                  </div>
                </div>
              </a>
            </div>
          {% endfor %}
        </div>
      </div>

      <button
        type="button"
        class="recipe-slider__button recipe-slider__button--next"
        aria-label="Next"
      >
        <svg
          class="w-[30px] max-w-[30px] h-[26px] max-h-[26px]"
          width="26"
          height="30"
          viewBox="0 0 26 30"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path fill-rule="evenodd" clip-rule="evenodd" d="M26 14.9432L11.5969 20.5387L-0.000222087 30L2.34005 14.9986L0.000217438 -6.67176e-05L11.332 9.24475L26 14.9432Z" fill="#112626"></path>
        </svg>
      </button>
    </div>

    {% if section.settings.button_label != blank %}
      <div class="recipe-slider__footer">
        <a
          href="{{ section.settings.button_link }}"
          class="recipe-slider__cta"
        >
          {{ section.settings.button_label }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Recipe Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What's cooking with smithey"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Recipe Blog"
    },
    {
      "type": "range",
      "id": "articles_to_show",
      "label": "Recipes to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "VIEW ALL RECIPES"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#112626"
    }
  ],
  "presets": [
    {
      "name": "Recipe Slider"
    }
  ]
}
{% endschema %}
