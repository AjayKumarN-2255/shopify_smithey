{{ 'recipie-products.css' | asset_url | stylesheet_tag }}
<script src="{{ 'recipie-products.js' | asset_url }}" defer></script>
<section
  class="recipe-slider"
  style="background-color: {{ section.settings.background_color }};"
>
  <div class="recipe-slider__wrapper">
    {% if section.settings.heading != blank %}
      <div class="recipe-slider__header">
        <h2 class="recipe-slider__heading">
          {{ section.settings.heading }}
        </h2>
      </div>
    {% endif %}

    <div class="recipe-slider__container">
      <button
        type="button"
        class="recipe-slider__button recipe-slider__button--prev"
        aria-label="Previous"
      >
        <svg
          class="w-[30px] max-w-[30px] h-[26px] max-h-[26px]"
          width="26"
          height="30"
          viewBox="0 0 26 30"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path fill-rule="evenodd" clip-rule="evenodd" d="M26 14.9432L11.5969 20.5387L-0.000222087 30L2.34005 14.9986L0.000217438 -6.67176e-05L11.332 9.24475L26 14.9432Z" fill="#112626"></path>
        </svg>
      </button>

      <div class="recipe-slider__viewport">
        <div class="recipe-slider__rail">
          {% assign blog = blogs[section.settings.blog] %}

          {% for article in blog.articles limit: section.settings.articles_to_show %}
            <div class="recipe-card">
              <a href="{{ article.url }}" class="recipe-card__link">
                <div class="recipe-card__image">
                  {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
                </div>

                <div class="recipe-card__content">
                  <h3 class="recipe-card__title">
                    {{ article.title }}
                  </h3>

                  <div class="recipe-card__meta">
                    <span class="recipe-card__servings">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="12"
                        height="15"
                        viewBox="0 0 12 15"
                        fill="none"
                        aria-hidden="true"
                      >
                        <path d="M9.64639 4.99763C8.25511 5.4955 6.98808 6.48821 5.98242 7.86853L1.21598 14.4107L0.791284 14.1012L5.55772 7.55911C6.56323 6.179 7.11984 4.6687 7.16754 3.19194C7.18525 2.6449 7.38754 2.07944 7.73724 1.59947C8.55289 0.479949 9.94507 0.10041 10.8412 0.753293C11.7375 1.40632 11.8029 2.84783 10.9873 3.96735C10.6377 4.44717 10.1615 4.81297 9.64639 4.99763ZM11.0006 0.534468C9.98389 -0.206282 8.42174 0.199732 7.5182 1.43989C7.13692 1.9632 6.91637 2.58226 6.89738 3.18306C6.8514 4.60544 6.31221 6.06332 5.33869 7.39952L0.492385 14.0513C0.448451 14.1116 0.461983 14.1966 0.522284 14.2406L1.16582 14.7094C1.22612 14.7533 1.31102 14.74 1.35496 14.6797L6.20126 8.02797C7.17478 6.69176 8.39765 5.73198 9.73781 5.25227C10.3035 5.04969 10.825 4.64989 11.2061 4.12678C12.1097 2.88662 12.0175 1.27536 11.0006 0.534468Z" fill="white"></path>
                      </svg>
                      Serves {{ article.metafields.custom.servings }}
                    </span>

                    <span class="recipe-card__cook-time">
                      <svg xmlns="http://www.w3.org/2000/svg" width="11" height="12" viewBox="0 0 11 12" fill="none">
                        <mask id="mask0_1_217" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="0" y="0" width="11" height="12">
                        <path d="M0.455627 0.106689H10.6677V11.3367H0.455627V0.106689Z" fill="white"></path>
                        </mask>
                        <g mask="url(#mask0_1_217)">
