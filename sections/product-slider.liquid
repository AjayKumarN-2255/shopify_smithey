{{ 'product-slider.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-slider.js' | asset_url }}" defer></script>

<section class="product-slider">
  <div class="product-slider__wrapper">
    {% if section.settings.heading != blank %}
      <div class="product-slider__header">
        <h2 class="product-slider__heading">
          {{ section.settings.heading }}
        </h2>
      </div>
    {% endif %}

    <div class="product-slider__container">
      <button
        type="button"
        class="product-slider__button product-slider__button--prev"
        aria-label="Previous"
      >
        <svg
          class="w-[30px] max-w-[30px] h-[26px] max-h-[26px]"
          width="26"
          height="30"
          viewBox="0 0 26 30"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path fill-rule="evenodd" clip-rule="evenodd" d="M26 14.9432L11.5969 20.5387L-0.000222087 30L2.34005 14.9986L0.000217438 -6.67176e-05L11.332 9.24475L26 14.9432Z" fill="#112626"></path>
        </svg>
      </button>

      <div class="product-slider__viewport">
        <div class="product-slider__rail">
          {% assign collection = collections[section.settings.collection] %}

          {% for product in collection.products limit: section.settings.products_to_show %}
            <div class="product-card">
              <a href="{{ product.url }}" class="product-card__link">
                <div class="product-card__image">
                  {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy' }}
                </div>

                <div class="product-card__content">
                  <div class="product-card__header">
                    <h3 class="product-card__title">
                      {{ product.title }}
                    </h3>

                    <span class="product-card__price">
                      {{ product.price | money }}
                    </span>
                  </div>

                  <p class="product-card__material">
                    {{ product.metafields.custom.material }}
                  </p>

                  <div class="product-card__reviews">
                    {% assign rating = product.metafields.custom.rating.value | default: 0 %}

                    <span class="product-card__rating">
                      {% for i in (1..5) %}
                        {% if i <= rating %}
                          ★
                        {% else %}
                          ☆
                        {% endif %}
                      {% endfor %}
                    </span>

                    <span class="product-card__review-count">
                      {{ product.metafields.custom.reviews_count }} Reviews
                    </span>
                  </div>
                </div>
              </a>
            </div>
          {% endfor %}
        </div>
      </div>

      <button
        type="button"
        class="product-slider__button product-slider__button--next"
        aria-label="Next"
      >
        <svg
          class="w-[30px] max-w-[30px] h-[26px] max-h-[26px]"
          width="26"
          height="30"
          viewBox="0 0 26 30"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path fill-rule="evenodd" clip-rule="evenodd" d="M26 14.9432L11.5969 20.5387L-0.000222087 30L2.34005 14.9986L0.000217438 -6.67176e-05L11.332 9.24475L26 14.9432Z" fill="#112626"></path>
        </svg>
      </button>
    </div>

    {% if section.settings.button_label != blank %}
      <div class="product-slider__footer">
        <a
          href="{{ section.settings.button_link }}"
          class="product-slider__cta"
        >
          {{ section.settings.button_label }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Product Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "AT HOME ON OUR RANGE..."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "SHOP ALL BEST SELLERS"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Product Slider"
    }
  ]
}
{% endschema %}
